{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "functions": {
    "api/app.py": {
      "runtime": "@vercel/python@<version that uses 3.11 or earlier>"
    }
  }
}
